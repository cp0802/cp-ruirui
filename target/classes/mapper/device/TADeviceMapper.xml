<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.adanxing.ad.user.dao.TADao">

    <select id="listByDeviceId" parameterType="java.lang.String" resultType="com.adanxing.ad.user.model.TADeviceInfo">
        select *
        from device.device_ta
        where did = #{deviceId}
    </select>

    <select id="getCheckList" parameterType="java.lang.String" resultType="com.adanxing.ad.user.model.TADeviceInfo">
        select *
        from ${tableName}
    </select>

    <select id="selectTAList" parameterType="java.util.Map" resultType="com.adanxing.ad.user.model.TADeviceInfo">
        select *
        from device.device_ta
        <where>
            <if test="dealId != null">
                and deal_id = #{dealId}
            </if>
        </where>
        <if test="limitSize != null">
            order by did asc limit ${startCount}, ${limitSize}
        </if>
    </select>

    <insert id="insertList" parameterType="com.adanxing.ad.user.model.TADeviceInfo">
        insert into device.device_ta(`did`, `did_type`, `deal_id`, `status`, `code`, `desc`, `result_content`, log_time)
        values
        <foreach collection="list" item="item" index="index" separator=",">
            (#{item.did},#{item.didType},#{item.dealId},#{item.status},#{item.code},#{item.desc},#{item.resultContent}, #{item.logTime})
        </foreach>
    </insert>

    <delete id="deleteTagDeviceByDid" parameterType="java.lang.String">
        alter table device.device_crowd_tag delete where did = #{deviceId}
    </delete>

    <insert id="insertTagDeviceList" parameterType="com.adanxing.ad.user.model.TagDeviceInfo">
        insert into device.device_crowd_tag(did, did_type, tag_type, tag_value, log_time)
        values
        <foreach collection="list" item="item" index="index" separator=",">
            (#{item.did},#{item.didType},#{item.tagType},#{item.tagValue},#{item.logTime})
        </foreach>
    </insert>
    <select id="queryDevice" parameterType="java.util.Map" resultType="com.adanxing.ad.user.model.TADeviceInfo">
        select did,did_type from ${tableName}
        <where>

            <if test="logTime != null">
                 log_time =#{logTime}
            </if>
            <if test="mediaId != null">
                and media_id =#{mediaId}
            </if>
        </where>
        <if test="limitSize != null">
            order by did asc limit ${startCount}, ${limitSize}
        </if>
    </select>
</mapper>